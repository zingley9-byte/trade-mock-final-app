# ─────────────────────────────────────────────────────────────────────────────
# Trade Mock Pro — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to git — add it to .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────────────────────
# Required: Firebase Web API Key (from Firebase Console → Project Settings)
# The other Firebase values (authDomain, projectId, etc.) are already set
# in lib/firebase.ts — only the API key is secret and must be in env.
FIREBASE_API_KEY=your_firebase_api_key_here

# ── Binance API (server-side only — never expose in frontend) ─────────────────
# Used by the API server to sign private Binance requests (if needed).
# Public market data endpoints do NOT require a key.
BINANCE_API_KEY=your_binance_api_key_here

# ── Google AdMob (for native Android/iOS builds via EAS Build) ───────────────
# Replace with your real AdMob App IDs from https://admob.google.com
# TEST IDs are already set as fallbacks in config/admob.ts — these env vars
# are only needed when building for the Play Store / App Store.
#
# REPLACE before Play Store launch:
ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# ── Session (API server) ──────────────────────────────────────────────────────
# Random secret string for Express session signing (min 32 chars recommended).
SESSION_SECRET=your_random_session_secret_here
