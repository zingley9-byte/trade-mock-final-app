# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# pnpm store — not needed at runtime
.local

# Git history and LFS objects (~15 GiB) — never needed at runtime
.git

# All node_modules — not needed at runtime:
#   - API server uses a self-contained esbuild bundle
#   - Mobile app uses a zero-dependency static server
node_modules
**/node_modules

# Build caches
.cache

# Large archive files (e.g. project.zip snapshots)
*.zip
